# Supabase API endpoint (e.g., https://yourproject.supabase.co)
SUPABASE_URL=

# Supabase Anonymous Key (used for public authentication operations)
SUPABASE_ANON_KEY=

# Supabase Service Role Key (secret key, bypasses RLS - keep safe!)
SUPABASE_SERVICE_ROLE_KEY=

# Supabase JWT Secret (found in Settings -> API -> JWT Settings)
# Used for fast, local validation of JWTs
SUPABASE_JWT_SECRET=

# Path to the pretrained ML model file (ONNX or Keras)
# Defaults to backend/app/inference/model.onnx if not specified
# MODEL_PATH=backend/app/inference/model.onnx
